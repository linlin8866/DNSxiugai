#!/bin/bash

# 1. 解锁 resolv.conf（兼容新系统）
chattr -i /etc/resolv.conf 2>/dev/null

# 2. 温和禁用 systemd-resolved
systemctl stop systemd-resolved
systemctl disable systemd-resolved

# 3. 写入完整 DNS 配置（包含你新增的地址）
rm -f /etc/resolv.conf
cat > /etc/resolv.conf <<EOF
nameserver 95.85.95.85
nameserver 2.56.220.2
nameserver 208.67.222.222
nameserver 8.8.4.4
nameserver 2a03:90c0:999d::1
nameserver 2a03:90c0:9992::1
nameserver 2001:4860:4860::8888
nameserver 2620:0:ccc::2
EOF

# 4. 锁定文件，禁止任何程序修改
chattr +i /etc/resolv.conf

# 5. 防止 NetworkManager 覆盖
if command -v nmcli &> /dev/null; then
    mkdir -p /etc/NetworkManager/conf.d
    cat > /etc/NetworkManager/conf.d/90-dns-none.conf <<EOF
[main]
dns=none
rc-manager=unmanaged
EOF
    systemctl reload NetworkManager
fi

# 6. 验证结果
echo -e "\n✅ DNS 已永久锁定，当前配置："
cat /etc/resolv.conf
echo -e "\n🔍 测试网络连通性："
ping -c 2 8.8.8.8
echo -e "\n🔍 测试域名解析："
ping -c 2 google.com





